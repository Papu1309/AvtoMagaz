<Page x:Class="AvtoMagaz.Pages.PaymentPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AvtoMagaz.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PaymentPage">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
        <TextBlock Text="Оплата заказа" FontSize="20" Margin="10"/>
        <TextBlock x:Name="txtOrderInfo" Margin="5"/>
        <TextBlock Text="Сумма к оплате:" Margin="5"/>
        <TextBlock x:Name="txtAmount" FontWeight="Bold" Margin="5"/>
        <RadioButton x:Name="rbCard" Content="Карта" GroupName="PaymentMethod" Margin="5" IsChecked="True"/>
        <RadioButton x:Name="rbCash" Content="Наличные" GroupName="PaymentMethod" Margin="5"/>
        <Button Content="Оплатить" Margin="5" Padding="5" Click="Pay_Click"/>
        <Button Content="Отмена" Margin="5" Padding="5" Click="Cancel_Click"/>
    </StackPanel>
</Page>
