<Page x:Class="AvtoMagaz.Pages.AdminMainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AvtoMagaz.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdminMainPage">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock Text="Панель администратора" FontSize="20" Margin="10"/>
        <TextBlock x:Name="txtAdmin" FontSize="16" Margin="5"/>
        <Button Content="Управление товарами" Width="200" Height="40" Margin="5" Click="Products_Click"/>
        <Button Content="Все заказы" Width="200" Height="40" Margin="5" Click="Orders_Click"/>
        <Button Content="Выход" Width="200" Height="40" Margin="5" Click="Logout_Click"/>
    </StackPanel>
</Page>
