<Page x:Class="AvtoMagaz.Pages.CartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AvtoMagaz.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CartPage" Background="Beige">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Ваша корзина" FontSize="20" Margin="5"/>

        <ListView x:Name="lvCart" Grid.Row="1" Margin="5">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Товар" DisplayMemberBinding="{Binding ProductName}" Width="200"/>
                    <GridViewColumn Header="Цена" DisplayMemberBinding="{Binding Price, StringFormat={}{0:C}}" Width="100"/>
                    <GridViewColumn Header="Количество" Width="120">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox x:Name="txtQty" Text="{Binding Quantity}" Width="50" Margin="2"/>
                                    <Button Content="Обновить" Padding="5,2" Click="UpdateQty_Click" Tag="{Binding ProductId}"/>
                                </StackPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Header="Сумма" DisplayMemberBinding="{Binding Total, StringFormat={}{0:C}}" Width="100"/>
                    <GridViewColumn Header="Действие" Width="80">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Удалить" Padding="5,2" Click="Remove_Click" Tag="{Binding ProductId}"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="5">
            <TextBlock x:Name="txtTotal" Text="Итого: 0 руб." FontWeight="Bold" VerticalAlignment="Center" Margin="5"/>
            <Button Content="Оформить заказ" Padding="10,5" Click="Checkout_Click"/>
            <Button Content="Продолжить покупки" Padding="10,5" Margin="5,0,0,0" Click="Continue_Click"/>
        </StackPanel>
    </Grid>
</Page>
