<Page x:Class="AvtoMagaz.Pages.UserMainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AvtoMagaz.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="UserMainPage">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock Text="Добро пожаловать в автомагазин!" FontSize="20" Margin="10"/>
        <TextBlock x:Name="txtUser" FontSize="16" Margin="5"/>
        <Button Content="Каталог товаров" Width="200" Height="40" Margin="5" Click="Catalog_Click"/>
        <Button Content="Корзина" Width="200" Height="40" Margin="5" Click="Cart_Click"/>
        <Button Content="Мои заказы" Width="200" Height="40" Margin="5" Click="Orders_Click"/>
        <Button Content="Выход" Width="200" Height="40" Margin="5" Click="Logout_Click"/>
    </StackPanel>
</Page>
