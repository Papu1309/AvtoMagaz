<Page x:Class="AvtoMagaz.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AvtoMagaz.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage">

    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
        <TextBlock Text="Авторизация" FontSize="20" Margin="10"/>
        <TextBox x:Name="txtLogin" Margin="5" Padding="5" Text="user"/>
        <PasswordBox x:Name="txtPassword" Margin="5" Padding="5" Password="user123"/>
        <Button Content="Войти" Margin="5" Padding="5" Click="Login_Click"/>
        <Button Content="Регистрация" Margin="5" Padding="5" Click="Register_Click"/>
    </StackPanel>
</Page>
