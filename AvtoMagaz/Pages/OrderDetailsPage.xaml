<Page x:Class="AvtoMagaz.Pages.OrderDetailsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:AvtoMagaz.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="OrderDetailsPage" Background="Beige">

    <StackPanel Margin="10">
        <TextBlock x:Name="txtOrderInfo" FontSize="16" FontWeight="Bold" Margin="5"/>

        <TextBlock Text="Состав заказа:" Margin="5,10,5,5"/>
        <ListView x:Name="lvItems" Margin="5" MaxHeight="200">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Товар" DisplayMemberBinding="{Binding Name}" Width="200"/>
                    <GridViewColumn Header="Кол-во" DisplayMemberBinding="{Binding Quantity}" Width="80"/>
                    <GridViewColumn Header="Цена" DisplayMemberBinding="{Binding Price, StringFormat={}{0:C}}" Width="100"/>
                    <GridViewColumn Header="Сумма" DisplayMemberBinding="{Binding Sum, StringFormat={}{0:C}}" Width="100"/>
                </GridView>
            </ListView.View>
        </ListView>

        <TextBlock Text="Информация об оплате:" Margin="5,10,5,5"/>
        <ListView x:Name="lvPayments" Margin="5" MaxHeight="100">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Способ" DisplayMemberBinding="{Binding PaymentMethod}" Width="100"/>
                    <GridViewColumn Header="Сумма" DisplayMemberBinding="{Binding Amount, StringFormat={}{0:C}}" Width="100"/>
                    <GridViewColumn Header="Дата" DisplayMemberBinding="{Binding PaymentDate}" Width="150"/>
                </GridView>
            </ListView.View>
        </ListView>

        <Button Content="Назад" Padding="10,5" Width="100" HorizontalAlignment="Center" Margin="10" Click="Back_Click"/>
    </StackPanel>
</Page>
