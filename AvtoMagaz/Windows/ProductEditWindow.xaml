<Window x:Class="AvtoMagaz.Windows.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AvtoMagaz.Windows"
        mc:Ignorable="d"
        Title="ProductEditWindow" Height="450" Width="800">
    <StackPanel Margin="10">
        <TextBlock Text="Название:"/>
        <TextBox x:Name="txtName" Margin="5"/>
        <TextBlock Text="Описание:"/>
        <TextBox x:Name="txtDescription" Margin="5" Height="60" TextWrapping="Wrap"/>
        <TextBlock Text="Цена:"/>
        <TextBox x:Name="txtPrice" Margin="5"/>
        <TextBlock Text="Количество на складе:"/>
        <TextBox x:Name="txtStock" Margin="5"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="10">
            <Button Content="Сохранить" Padding="10,5" Click="Save_Click" />
            <Button Content="Отмена" Padding="10,5" Margin="5,0" Click="Cancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
