<Window x:Class="AvtoMagaz.Windows.PaymentCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AvtoMagaz.Windows"
        mc:Ignorable="d"
        Title="PaymentCardWindow" Height="450" Width="800">
    <StackPanel Margin="20">
        <TextBlock Text="Введите данные карты" Style="{StaticResource HeaderStyle}" HorizontalAlignment="Center"/>

        <TextBlock Text="Номер карты" Margin="0,10,0,0"/>
        <TextBox x:Name="txtCardNumber" MaxLength="16" TextChanged="ValidateInput"/>

        <TextBlock Text="Срок действия (ММ/ГГ)" Margin="0,10,0,0"/>
        <StackPanel Orientation="Horizontal">
            <TextBox x:Name="txtMonth" Width="50" MaxLength="2" TextChanged="ValidateInput"/>
            <TextBlock Text="/" VerticalAlignment="Center" Margin="5,0"/>
            <TextBox x:Name="txtYear" Width="50" MaxLength="2" TextChanged="ValidateInput"/>
        </StackPanel>

        <TextBlock Text="CVV" Margin="0,10,0,0"/>
        <TextBox x:Name="txtCvv" Width="80" MaxLength="3" TextChanged="ValidateInput"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button Content="Оплатить" x:Name="btnPay" IsEnabled="False" Click="Pay_Click" Padding="20,10"/>
            <Button Content="Отмена" Margin="10,0,0,0" Click="Cancel_Click" Padding="20,10"/>
        </StackPanel>

        <TextBlock x:Name="txtError"  TextWrapping="Wrap" Margin="0,10,0,0"/>
    </StackPanel>
</Window>
